<Window x:Class="Voip.Client.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:Voip.Shared;assembly=Voip.Shared"
        Title="VoIP Client"
        Height="500"
        Width="440"
        ResizeMode="CanMinimize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Server" FontWeight="SemiBold" />
        <TextBox x:Name="ServerBox"
                 Grid.Row="1"
                 Margin="0,6,0,12"
                 Text="ws://localhost:8181" />

        <TextBlock Grid.Row="2" Text="Username" FontWeight="SemiBold" />
        <TextBox x:Name="UserNameBox"
                 Grid.Row="3"
                 Margin="0,6,0,12"
                 Text="user1" />

        <TextBlock Grid.Row="4" Text="Room" FontWeight="SemiBold" />
        <Grid Grid.Row="5"
              Margin="0,6,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="RoomBox"
                      Grid.Column="0"
                      MinHeight="28"
                      IsEditable="False" />
            <Button x:Name="ChangeRoomButton"
                    Grid.Column="2"
                    Padding="14,4"
                    Content="Change Room"
                    IsEnabled="False"
                    Click="ChangeRoom_Click" />
        </Grid>

        <StackPanel Grid.Row="6">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="ConnectButton"
                        Grid.Column="0"
                        Height="34"
                        Content="Connect"
                        Click="Connect_Click" />
                <Button x:Name="DisconnectButton"
                        Grid.Column="2"
                        Height="34"
                        Content="Disconnect"
                        IsEnabled="False"
                        Click="Disconnect_Click" />
            </Grid>

            <ToggleButton x:Name="MicToggleButton"
                          Height="34"
                          Margin="0,0,0,10"
                          Content="Mic Off"
                          IsEnabled="False"
                          Checked="MicToggleChanged"
                          Unchecked="MicToggleChanged" />
            <Button x:Name="TalkButton"
                    Height="42"
                    Content="Hold To Talk"
                    IsEnabled="False"
                    PreviewMouseDown="StartTalk"
                    PreviewMouseUp="StopTalk"
                    LostMouseCapture="TalkLostMouseCapture" />
            <TextBlock x:Name="Status"
                       Margin="0,12,0,0"
                       Text="Disconnected"
                       TextWrapping="Wrap" />
        </StackPanel>

        <GroupBox Grid.Row="7"
                  Margin="0,14,0,0"
                  Header="Connected Users">
            <ListBox x:Name="UsersList"
                     MinHeight="150"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type shared:RoomUserStatus}">
                        <DockPanel Margin="0,4">
                            <TextBlock Margin="0,0,8,0"
                                       FontSize="12"
                                       FontWeight="SemiBold">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="[MUTED]" />
                                        <Setter Property="Foreground" Value="IndianRed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMutedByServer}" Value="True">
                                                <Setter Property="Text" Value="[SERVER MUTED]" />
                                                <Setter Property="Foreground" Value="DarkOrange" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsMicOn}" Value="True">
                                                <Setter Property="Text" Value="[MIC]" />
                                                <Setter Property="Foreground" Value="SeaGreen" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding UserName}" />
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </GroupBox>
    </Grid>
</Window>
